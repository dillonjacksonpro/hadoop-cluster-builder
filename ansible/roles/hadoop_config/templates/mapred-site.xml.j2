<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <property>
    <name>mapreduce.framework.name</name>
    <value>yarn</value>
  </property>
  <property>
    <name>mapreduce.map.memory.mb</name>
    <value>{{ mapred_memory_mb }}</value>
  </property>
  <property>
    <name>mapreduce.reduce.memory.mb</name>
    <value>{{ mapred_memory_mb }}</value>
  </property>
  <property>
    <name>yarn.app.mapreduce.am.resource.mb</name>
    <value>{{ mapred_memory_mb }}</value>
  </property>
  <property>
    <name>mapreduce.map.java.opts</name>
    <value>-Xmx{{ (mapred_memory_mb * 0.8) | int }}m</value>
  </property>
  <property>
    <name>mapreduce.reduce.java.opts</name>
    <value>-Xmx{{ (mapred_memory_mb * 0.8) | int }}m</value>
  </property>
  <property>
    <name>mapreduce.jobhistory.address</name>
    <value>{{ hostvars[groups['namenode'][0]]['ansible_default_ipv4']['address'] }}:10020</value>
  </property>
  <property>
    <name>mapreduce.jobhistory.webapp.address</name>
    <value>{{ hostvars[groups['namenode'][0]]['ansible_default_ipv4']['address'] }}:19888</value>
  </property>
</configuration>
