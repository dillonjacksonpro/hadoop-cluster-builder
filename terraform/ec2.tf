# SSH key pair — generated by Terraform, private key written to local file
resource "tls_private_key" "hadoop" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "hadoop" {
  key_name   = var.key_name
  public_key = tls_private_key.hadoop.public_key_openssh

  tags = {
    Cluster = var.cluster_name
  }
}

resource "local_file" "private_key" {
  content         = tls_private_key.hadoop.private_key_pem
  filename        = "${path.module}/hadoop_key.pem"
  file_permission = "0600"
}

# NameNode (always exactly 1)
resource "aws_instance" "namenode" {
  ami                    = data.aws_ami.al2023.id
  instance_type          = var.namenode_type
  key_name               = aws_key_pair.hadoop.key_name
  subnet_id              = aws_subnet.main.id
  vpc_security_group_ids = [aws_security_group.internal.id, aws_security_group.external.id]
  iam_instance_profile   = aws_iam_instance_profile.hadoop.name

  root_block_device {
    volume_size           = 30
    volume_type           = "gp3"
    delete_on_termination = true
  }

  tags = {
    Name    = "${var.cluster_name}-namenode"
    Role    = "namenode"
    Cluster = var.cluster_name
  }
}

# DataNodes — only created when cluster_size > 1
resource "aws_instance" "datanode" {
  count                  = local.datanode_count
  ami                    = data.aws_ami.al2023.id
  instance_type          = var.instance_type
  key_name               = aws_key_pair.hadoop.key_name
  subnet_id              = aws_subnet.main.id
  vpc_security_group_ids = [aws_security_group.internal.id]
  iam_instance_profile   = aws_iam_instance_profile.hadoop.name

  root_block_device {
    volume_size           = 50
    volume_type           = "gp3"
    delete_on_termination = true
  }

  tags = {
    Name    = "${var.cluster_name}-datanode-${count.index}"
    Role    = "datanode"
    Cluster = var.cluster_name
  }
}
